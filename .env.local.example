# Supabase の接続情報（Settings → API で取得）
# このファイルを .env.local にコピーして実際の値を入れてください。
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=（anon または publishable key）

# --- Web Push（リマインドのプッシュ通知）---
# service_role キー（Settings → API）。サーバー専用の秘密鍵。絶対に公開しない。
SUPABASE_SERVICE_ROLE_KEY=（service_role key）

# VAPID 鍵（`npx web-push generate-vapid-keys` で生成）
NEXT_PUBLIC_VAPID_PUBLIC_KEY=（public key）
VAPID_PRIVATE_KEY=（private key）
VAPID_SUBJECT=mailto:you@example.com

# cron 用の共有シークレット（送信APIの保護。任意の長いランダム文字列）
CRON_SECRET=（ランダムな長い文字列）
